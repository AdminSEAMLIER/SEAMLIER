# Base de données PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/seamlier

# Secret pour les sessions (générer une chaîne aléatoire longue)
SESSION_SECRET=votre_secret_de_session_ici

# Port du serveur (optionnel, défaut: 5000)
PORT=5000

# Environnement
NODE_ENV=production

# Replit Auth (OIDC) - à adapter si vous n'utilisez plus Replit Auth
ISSUER_URL=https://replit.com/oidc
REPL_ID=votre_repl_id

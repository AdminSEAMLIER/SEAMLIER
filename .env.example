# ── Base de données MySQL ─────────────────────────────────────────────────────
DATABASE_URL=mysql://user:password@host:3306/seamlier

# ── Sessions ──────────────────────────────────────────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=votre_secret_de_session_ici_64_caracteres_min

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# IDs des prix Stripe pour les abonnements Pro artisans
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=mail.seamlier.fr
SMTP_PORT=465
SMTP_USER=contact@seamlier.fr
SMTP_FROM=contact@seamlier.fr
# Mot de passe SMTP (ou via SMTP_PASS)
EMAIL_PASSWORD=votre_mot_de_passe_smtp

# ── SMS (Twilio) ──────────────────────────────────────────────────────────────
# Laisser vide pour désactiver les SMS (degradation silencieuse)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=votre_auth_token_twilio
TWILIO_FROM_NUMBER=+33xxxxxxxxx

# ── Application ───────────────────────────────────────────────────────────────
APP_URL=https://www.seamlier.fr
# Email de l'administrateur (alertes Kbis, recapitulatifs fiscaux)
ADMIN_EMAIL=contact@seamlier.fr
# Mot de passe temporaire assigne aux artisans crees manuellement par l'admin
DEFAULT_TAILOR_PASSWORD=changez_ce_mot_de_passe_en_prod

# ── Serveur ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

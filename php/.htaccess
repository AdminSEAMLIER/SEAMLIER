# SEAMLIER - Configuration Apache pour o2switch
# Placer ce fichier à la racine du site (public_html/)

# ===== Forcer HTTPS =====
RewriteEngine On
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ===== Fichiers PHP (API backend dans /php/) =====
RewriteRule ^php/ - [L]

# ===== Fichiers statiques existants (JS, CSS, images, fonts) =====
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# ===== Toutes les autres requêtes → index.html (SPA React Router) =====
# Cela couvre : /admin/seamlier, /particulier/*, /professionnel/*, etc.
RewriteRule ^ index.html [L]
